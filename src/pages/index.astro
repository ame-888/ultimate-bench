                                    <span class="zone-name" style={`font-weight: ${sotaScore >= 60 ? '800' : '500'}; color: ${sotaScore >= 60 ? '#F97316' : '#4B5563'}; text-shadow: ${sotaScore >= 60 ? '0 0 8px rgba(249, 115, 22, 0.5)' : 'none'}; font-size: 1.2rem;`}>SUPERNOVA</span>
                                </div>

                                <!-- 40-60% (Star) - Center at 50% from bottom (50% from top) -->
                                <div class={`sota-zone-label ${sotaScore >= 40 ? 'active' : ''}`} style="position: absolute; top: 50%; transform: translateY(-50%); transition: all 0.3s ease;">
                                    <span class="zone-name" style={`font-weight: ${sotaScore >= 40 ? '800' : '500'}; color: ${sotaScore >= 40 ? '#EF4444' : '#4B5563'}; text-shadow: ${sotaScore >= 40 ? '0 0 8px rgba(239, 68, 68, 0.5)' : 'none'}; font-size: 1.2rem;`}>STAR</span>
                                </div>

                                <!-- 20-40% (Nebula) - Center at 30% from bottom (70% from top) -->
                                <div class={`sota-zone-label ${sotaScore >= 20 ? 'active' : ''}`} style="position: absolute; top: 70%; transform: translateY(-50%); transition: all 0.3s ease;">
                                    <span class="zone-name" style={`font-weight: ${sotaScore >= 20 ? '800' : '500'}; color: ${sotaScore >= 20 ? '#A855F7' : '#4B5563'}; text-shadow: ${sotaScore >= 20 ? '0 0 8px rgba(168, 85, 247, 0.5)' : 'none'}; font-size: 1.2rem;`}>NEBULA</span>
                                </div>

                                <!-- 0-20% (Event Horizon) - Center at 10% from bottom (90% from top) -->
                                <div class={`sota-zone-label ${sotaScore >= 0 ? 'active' : ''}`} style="position: absolute; top: 90%; transform: translateY(-50%); transition: all 0.3s ease;">
                                    <span class="zone-name" style={`font-weight: ${sotaScore >= 0 ? '800' : '500'}; color: ${sotaScore >= 0 ? '#3B82F6' : '#4B5563'}; text-shadow: ${sotaScore >= 0 ? '0 0 8px rgba(59, 130, 246, 0.5)' : 'none'}; font-size: 1.2rem;`}>EVENT HORIZON</span>
                                </div>
                            </div>
