                                    <div class="col-header" style="justify-content: flex-end; text-align: center;"><h3 style="color: #D1D5DB; text-align: center;">VISUAL</h3><div class="creature-icon"></div></div>
                                    <div class="col-header" style="justify-content: flex-end; text-align: center;"><h3 style="color: #D1D5DB; text-align: center;">DATA</h3><div class="creature-icon"></div></div>
                                    <div class="col-header" style="justify-content: flex-end; text-align: center;"><h3 style="color: #D1D5DB; text-align: center;">CHESS</h3><div class="creature-icon"></div></div>
                                    <div class="col-header" style="justify-content: flex-end; text-align: center;">
                                        <div class="header-title-wrapper" id="ultimate-sort-btn" style="border-bottom: none; cursor: pointer; transition: opacity 0.2s ease; margin-bottom: 0; padding-bottom: 0;">
                                            <h3 style="color: #F59E0B; font-weight: 900; text-align: center;" id="ultimate-sort-text">ULTIMATE AVG ▼</h3>
                                        </div>
                                        <div class="creature-icon"></div>
                                    </div>
                                </div>
                                {ultimateBenchList.map((item, index) => (
                                    <div class={`benchmark-row unified-row ultimate-row-hover `} style="grid-template-columns: 80px minmax(340px, max-content) 1fr 1fr 1fr 1.5fr; padding: 0.75rem 1rem; border-bottom: 1px solid rgba(55, 65, 81, 0.5);">
                                        <div class="benchmark-cell" style="justify-content: center; font-size: 1.25rem;">
                                            <div class="rank" set:html={getRankDisplay(item.rank)}></div>
                                        </div>
                                        <div class={`benchmark-cell model-cell ${getModelColorClass(item.name)}`} style="justify-content: flex-start; border-radius: 4px; padding-right: 2rem;">
                                            <div class="benchmark-content" style="padding-left: 0.5rem;">
                                                <div class="model-info">
                                                    <div class="model-name" data-release-date={item.releaseDate} style="font-size: 1.1rem; font-weight: 600;">
                                                        {item.name === 'Claude 4.6 Sonnet (adaptative thinking)' ? 'Claude 4.6 Sonnet (Adaptative)' : item.name}
                                                        {isNew(item.releaseDate) && <span class="new-badge" style="transform: scale(0.8); margin-left: 0.5rem;">NEW</span>}
                                                    </div>
                                                </div>
                                            </div>
