import Layout from '../layouts/Layout.astro';
import { benchmarks } from '../data/benchmarks';
import { getSimulatedDate, TIME_OFFSET } from '../scripts/TimeUtils';



// --- Simulated Time for Context ---
const SIMULATED_NOW = getSimulatedDate();

function isNew(dateStr) {
    if (!dateStr) return false;
    const release = new Date(dateStr);
    const now = new Date(SIMULATED_NOW);
    // Reset hours to compare just dates
    release.setHours(0,0,0,0);
    now.setHours(0,0,0,0);

    const diffTime = now.getTime() - release.getTime();
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

    // Show new for items released in the last 30 days
    return diffDays >= -1 && diffDays <= 30;
}

function getModelColorClass(name) {
    const lowerName = name.toLowerCase();
    if (lowerName.includes('gemini')) return 'model-bg-gemini';
    if (lowerName.includes('muse')) return 'model-bg-muse';
    if (lowerName.includes('gpt')) return 'model-bg-gpt';
    if (lowerName.includes('grok')) return 'model-bg-grok';
    if (lowerName.includes('claude')) return 'model-bg-claude';
    return '';
}

// --- Ranking Logic ---
function computeRanks(items, scoreKeys) {
    const keys = Array.isArray(scoreKeys) ? scoreKeys : [scoreKeys];

    // 1. Sort
    let sorted = [...items].sort((a, b) => {
        for (const key of keys) {
            const valA = typeof a[key] === 'number' ? a[key] : 0;
            const valB = typeof b[key] === 'number' ? b[key] : 0;
            if (valB !== valA) {
                return valB - valA;
            }
        }
        return 0;
    });

    // 3. Assign ranks
    let currentRank = 1;
    let previousItem = null;
    let rankedItems = [];

    sorted.forEach((item) => {
        if (previousItem !== null) {
            let isWorse = false;
            for (const key of keys) {
                const itemVal = typeof item[key] === 'number' ? item[key] : 0;
                const prevVal = typeof previousItem[key] === 'number' ? previousItem[key] : 0;
                if (itemVal < prevVal) {
                    isWorse = true;
                    break;
                } else if (itemVal > prevVal) {
                    break;
                }
            }
            if (isWorse) {
                currentRank++;
            }
        }

        rankedItems.push({ ...item, rank: currentRank, isFail: false });
        previousItem = item;
    });

    return rankedItems;
}


// --- Unify Benchmark Data for Visual Mode ---
const unifiedDataMap = new Map();

benchmarks.models.forEach(m => {
    unifiedDataMap.set(m.name, {
        name: m.name,
        releaseDate: m.releaseDate,
        lvl1: m.scores.lvl1,
        lvl2: m.scores.lvl2,
        lvl3: m.scores.lvl3,
        lvl4: m.scores.lvl4,
        lvl5: m.scores.lvl5,
        lvl6: '?'
    });
});



const unifiedRawList = Array.from(unifiedDataMap.values()).map(m => {
    let total = m.lvl1 + m.lvl2 + m.lvl3 + m.lvl4 + m.lvl5;
    // Average removed in favor of level-by-level fallback ranking

    return m;
});

const unifiedList = computeRanks(unifiedRawList, ['lvl1', 'lvl2', 'lvl3', 'lvl4', 'lvl5']);

// Calculate best AI scores for each column to apply the golden aura
const bestAiScores = { lvl1: -1, lvl2: -1, lvl3: -1, lvl4: -1, lvl5: -1 };
unifiedList.forEach(item => {
            if (item.lvl1 !== undefined && item.lvl1 > bestAiScores.lvl1 && typeof item.lvl1 === 'number') bestAiScores.lvl1 = item.lvl1;
        if (item.lvl2 !== undefined && item.lvl2 > bestAiScores.lvl2 && typeof item.lvl2 === 'number') bestAiScores.lvl2 = item.lvl2;
        if (item.lvl3 !== undefined && item.lvl3 > bestAiScores.lvl3 && typeof item.lvl3 === 'number') bestAiScores.lvl3 = item.lvl3;
        if (item.lvl4 !== undefined && item.lvl4 > bestAiScores.lvl4 && typeof item.lvl4 === 'number') bestAiScores.lvl4 = item.lvl4;
        if (item.lvl5 !== undefined && item.lvl5 > bestAiScores.lvl5 && typeof item.lvl5 === 'number') bestAiScores.lvl5 = item.lvl5;
});

const rows = Array.from({ length: unifiedList.length }, (_, i) => i);

// Data Retrieval Logic
const dataDataMap = new Map();

(benchmarks.dataRetrieval || []).forEach(m => {
    dataDataMap.set(m.name, {
        name: m.name,
        releaseDate: m.releaseDate,
        worm: m.scores?.worm,
        koala: m.scores?.koala,
        crow: m.scores?.crow,
        octopus: m.scores?.octopus,
        raven: '?',
        athena: '?'
    });
});

const dataRawList = Array.from(dataDataMap.values()).map(m => {
    const wormScore = typeof m.worm === 'number' ? m.worm : 0;
    const koalaScore = typeof m.koala === 'number' ? m.koala : 0;
    const crowScore = typeof m.crow === 'number' ? m.crow : 0;
    const octopusScore = typeof m.octopus === 'number' ? m.octopus : 0;
    return m;
});

const dataList = computeRanks(dataRawList, ['worm', 'koala', 'crow', 'octopus']);

const bestDataAiScores = { worm: -1, koala: -1, crow: -1, octopus: -1 };
dataList.forEach(item => {
            if (typeof item.worm === 'number' && item.worm > bestDataAiScores.worm) bestDataAiScores.worm = item.worm;
        if (typeof item.koala === 'number' && item.koala > bestDataAiScores.koala) bestDataAiScores.koala = item.koala;
        if (typeof item.crow === 'number' && item.crow > bestDataAiScores.crow) bestDataAiScores.crow = item.crow;
        if (typeof item.octopus === 'number' && item.octopus > bestDataAiScores.octopus) bestDataAiScores.octopus = item.octopus;
});

// --- Intrinsic Complexity Global Score Logic ---
function computeGlobalScores(list, weights, keys) {
    const globalScores = list.map(item => {
        let multiplierSum = 0;
        let divisorSum = 0;
        let attemptedCount = 0;
        let unavailableCount = 0;

        keys.forEach(k => {
            let val = item[k];
            if (val === 'UNAVAILABLE') {
                unavailableCount++;
            }
            if (val === 'UNAVAILABLE' || val === undefined) {
                // Ignore completely
                return;
            }

            attemptedCount++;
            let numVal = val === 'INVALID' ? 0 : (typeof val === 'number' ? val : 0);

            const weight = weights[k];
            multiplierSum += (numVal * weight);
            divisorSum += weight;
        });

        const score = divisorSum > 0 ? (multiplierSum / divisorSum) : 0;

        return {
            ...item,
            globalScore: score,
            hasData: attemptedCount > 0,
            qualifiesForGlobal: unavailableCount <= 1
        };
    });

    // Filter out models with no data, sort descending, assign rank
    const sorted = globalScores
        .filter(item => item.hasData && item.qualifiesForGlobal)
        .sort((a, b) => b.globalScore - a.globalScore);

    let currentRank = 1;
    let prevScore = null;
    return sorted.map(item => {
        if (prevScore !== null && item.globalScore < prevScore) {
            currentRank++;
        }
        prevScore = item.globalScore;
        return { ...item, rank: currentRank };
    });
}

const visualWeights = { lvl1: 10, lvl2: 15, lvl3: 35, lvl4: 100, lvl5: 250, lvl6: 500 };
const dataWeights = { worm: 10, koala: 20, crow: 45, octopus: 120, raven: 250, athena: 500 };

const visualGlobalList = computeGlobalScores(unifiedRawList, visualWeights, ['lvl1', 'lvl2', 'lvl3', 'lvl4', 'lvl5']);
const dataGlobalList = computeGlobalScores(dataRawList, dataWeights, ['worm', 'koala', 'crow', 'octopus']);

const rowsData = Array.from({ length: dataList.length }, (_, i) => i);

// Chess Benchmark Logic
const chessDataMap = new Map();

(benchmarks.chessModels || []).forEach(m => {
    chessDataMap.set(m.name, {
        name: m.name,
        releaseDate: m.releaseDate,
        mouse: m.scores?.mouse,
        spider: m.scores?.spider,
        wolf: m.scores?.wolf,
        hawk: m.scores?.hawk,
        python: m.scores?.python,
        hydra: m.scores?.hydra
    });
});

const chessRawList = Array.from(chessDataMap.values()).map(m => {
    const mouseScore = typeof m.mouse === 'number' ? m.mouse : 0;
    const spiderScore = typeof m.spider === 'number' ? m.spider : 0;
    const wolfScore = typeof m.wolf === 'number' ? m.wolf : 0;
    const hawkScore = typeof m.hawk === 'number' ? m.hawk : 0;
    const pythonScore = typeof m.python === 'number' ? m.python : 0;
    const hydraScore = typeof m.hydra === 'number' ? m.hydra : 0;
    return m;
});

const chessList = computeRanks(chessRawList, ['mouse', 'spider', 'wolf', 'hawk', 'python', 'hydra']);

const bestChessAiScores = { mouse: -1, spider: -1, wolf: -1, hawk: -1, python: -1, hydra: -1 };
chessList.forEach(item => {
    if (typeof item.mouse === 'number' && item.mouse > bestChessAiScores.mouse) bestChessAiScores.mouse = item.mouse;
    if (typeof item.spider === 'number' && item.spider > bestChessAiScores.spider) bestChessAiScores.spider = item.spider;
    if (typeof item.wolf === 'number' && item.wolf > bestChessAiScores.wolf) bestChessAiScores.wolf = item.wolf;
    if (typeof item.hawk === 'number' && item.hawk > bestChessAiScores.hawk) bestChessAiScores.hawk = item.hawk;
    if (typeof item.python === 'number' && item.python > bestChessAiScores.python) bestChessAiScores.python = item.python;
    if (typeof item.hydra === 'number' && item.hydra > bestChessAiScores.hydra) bestChessAiScores.hydra = item.hydra;
});

const chessWeights = { mouse: 10, spider: 20, wolf: 45, hawk: 120, python: 250, hydra: 500 };
const chessGlobalList = computeGlobalScores(chessRawList, chessWeights, ['mouse', 'spider', 'wolf', 'hawk', 'python', 'hydra']);

const rowsChess = Array.from({ length: chessList.length }, (_, i) => i);


function getPixelMedal(rank) {
    let color1, color2, color3;
    if (rank === 1) { color1 = '#FFD700'; color2 = '#DAA520'; color3 = '#B8860B'; } // Gold
    else if (rank === 2) { color1 = '#E0E0E0'; color2 = '#C0C0C0'; color3 = '#A9A9A9'; } // Silver
    else if (rank === 3) { color1 = '#CD7F32'; color2 = '#A0522D'; color3 = '#8B4513'; } // Bronze

    return `<svg width="24" height="24" viewBox="0 0 16 16" style="display:inline-block; vertical-align:middle; filter:drop-shadow(0 2px 2px rgba(0,0,0,0.5));">
        <path d="M4 2 h8 v2 h-8 z" fill="${color3}"/>
        <path d="M3 4 h10 v8 h-10 z" fill="${color2}"/>
        <path d="M4 5 h8 v6 h-8 z" fill="${color1}"/>
        <path d="M5 6 h6 v4 h-6 z" fill="#FFFFFF" fill-opacity="0.3"/>
        <path d="M4 12 h8 v2 h-8 z" fill="${color3}"/>
        <text x="8" y="9" font-family="monospace" font-size="6" font-weight="bold" fill="${color3}" text-anchor="middle" dominant-baseline="central">${rank}</text>
    </svg>`;
}


// --- Global Ultimate Bench Logic ---
const ultimateBenchMap = new Map();

visualGlobalList.forEach(item => {
    if (item.hasData && item.qualifiesForGlobal) {
        let cleanName = item.name.replace(/\*+$/, '');
        ultimateBenchMap.set(cleanName, {
            name: cleanName,
            releaseDate: item.releaseDate,
            visualScore: item.globalScore,
            dataScore: null,
            chessScore: null
        });
    }
});

dataGlobalList.forEach(item => {
    if (item.hasData && item.qualifiesForGlobal) {
        let nameToMatch = item.name.replace(/\*+$/, '');
        if (ultimateBenchMap.has(nameToMatch)) {
            const entry = ultimateBenchMap.get(nameToMatch);
            entry.dataScore = item.globalScore;
        }
    }
});

chessGlobalList.forEach(item => {
    if (item.hasData && item.qualifiesForGlobal) {
        let nameToMatch = item.name.replace(/\*+$/, '');
        if (ultimateBenchMap.has(nameToMatch)) {
            const entry = ultimateBenchMap.get(nameToMatch);
            entry.chessScore = item.globalScore;
        }
    }
});

let ultimateBenchList = Array.from(ultimateBenchMap.values())
    .filter(item => item.visualScore !== null && item.dataScore !== null && item.chessScore !== null)
    .map(item => {
        return {
            ...item,
            ultimateScore: (item.visualScore + item.dataScore + item.chessScore) / 3
        };
    })
    .sort((a, b) => b.ultimateScore - a.ultimateScore);

let ultRank = 1;
let ultPrevScore = null;
ultimateBenchList = ultimateBenchList.map(item => {
    if (ultPrevScore !== null && item.ultimateScore < ultPrevScore) {
        ultRank++;
    }
    ultPrevScore = item.ultimateScore;
    return { ...item, rank: ultRank };
});

function getRankDisplay(rank) {

    if (rank === '-') return '-';
    if (rank === 'INVALID') return `<span class="zero-score-glow">INVALID</span>`;
    return `${rank}`;
}

const sotaScore = ultimateBenchList.length > 0 ? ultimateBenchList[0].ultimateScore : 0;

