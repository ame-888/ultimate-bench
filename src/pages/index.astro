                                            <path d="M12 2C12 2 15 6 15 11C15 16 17 18 17 18H7C7 18 9 16 9 11C9 6 12 2 12 2Z" fill="#FBBF24" stroke="#B45309" stroke-width="1.5" stroke-linejoin="round"/>
                                            <path d="M12 18V22" stroke="#EF4444" stroke-width="3" stroke-linecap="round" class="propulsion-main"/>
                                            <path d="M9 18L7 21" stroke="#F97316" stroke-width="2" stroke-linecap="round" class="propulsion-left"/>
                                            <path d="M15 18L17 21" stroke="#F97316" stroke-width="2" stroke-linecap="round" class="propulsion-right"/>
                                            <circle cx="12" cy="10" r="1.5" fill="#1E3A8A"/>
                                        </svg>
                                        <div class="sota-score-label" style="position: absolute; left: 45px; background: rgba(17, 24, 39, 0.8); border: 1px solid #F59E0B; padding: 0.25rem 0.75rem; border-radius: 0.5rem; color: #F59E0B; font-weight: bold; font-family: monospace; font-size: 1.1rem;  box-shadow: 0 0 10px rgba(245, 158, 11, 0.3);">
                                            SOTA: {sotaScore.toFixed(1)}%
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- The 5 Zone Labels -->
                            <div class="sota-labels-container" style="position: absolute; height: 100%; top: 0; left: calc(50% + 50px); width: 250px; display: flex; flex-direction: column; justify-content: space-between; pointer-events: none;">
                                <!-- Placed absolutely by percentage to align exactly with the 5 zones -->
                                <!-- 80-100% (Singularity) - Center at 90% from bottom (10% from top) -->
                                <div class={`sota-zone-label ${sotaScore >= 80 ? 'active' : ''}`} style="position: absolute; top: 10%; transform: translateY(-50%); transition: all 0.3s ease;">
                                    <span class="zone-name" style={`font-weight: ${sotaScore >= 80 ? '800' : '500'}; color: ${sotaScore >= 80 ? '#FBBF24' : '#4B5563'}; text-shadow: ${sotaScore >= 80 ? '0 0 8px rgba(251, 191, 36, 0.5)' : 'none'}; font-size: 1.2rem;`}>SINGULARITY</span>
                                </div>

                                <!-- 60-80% (Supernova) - Center at 70% from bottom (30% from top) -->
