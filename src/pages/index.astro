<Layout  title="Leaderboard - Ultimate Bench">
    <main>



        <div class="leaderboard-grid">
            <!-- Benchmarks Section -->
            <section class="leaderboard-section full-width">


                <!-- Homepage Combined View -->
                <div id="home-wrapper">
                    <div class="benchmark-description">
                        <p>Welcome to Ultimate Bench. This is the Global Leaderboard summarizing the models' performance across all tasks using the Intrinsic Complexity scoring method.</p>
                    </div>

                    <!-- Ultimate Global Bench Section -->
                    <div class="ultimate-bench-section">
                        <div class="home-column-header ultimate-title-container" style="justify-content: center; margin-bottom: 2rem; position: relative;">
                            <h2 class="ultimate-title">GLOBAL ULTIMATE BENCH</h2>
                        </div>
                        <div class="benchmark-desktop-container ultimate-container">
                            <div class="benchmark-container visual-table ultimate-modern-container">
                                <div class="header-row unified-header-row ultimate-header-glass" style="grid-template-columns: 80px minmax(340px, max-content) 1fr 1fr 1fr 1.5fr; padding: 1rem; align-items: flex-end;">
                                    <div class="col-header" style="justify-content: flex-end;"><h3>RANK</h3><div class="creature-icon"></div></div>
