                                        <div class="benchmark-cell score-cell" style="justify-content: center; text-align: center; font-size: 1.1rem; color: #9CA3AF;">
                                            {item.visualScore.toFixed(1)}%
                                        </div>
                                        <div class="benchmark-cell score-cell" style="justify-content: center; text-align: center; font-size: 1.1rem; color: #9CA3AF;">
                                            {item.dataScore.toFixed(1)}%
