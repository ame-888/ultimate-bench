<nav class="navbar">
    <div class="navbar-container">
        <button class="navbar-toggle" id="navbar-toggle" aria-label="Toggle Navigation">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>

        <div class="navbar-menu" id="navbar-menu">
            <a href="/" id="nav-home" class="nav-link">HOME</a>
            <a href="/about" class="nav-link">About</a>
            <a href="/contact" class="nav-link">Contact</a>
            <a href="/terms" class="nav-link">Terms of Service</a>
            <a href="/privacy" class="nav-link">Privacy Policy</a>
            <a href="/arcade" id="nav-arcade" class="nav-link" style="color: #FACC15; font-weight: 700; margin-right: 1rem;">ARCADE</a>
        </div>

        <div class="navbar-end">
        </div>
    </div>
</nav>

<style>
    .navbar {
        background-color: rgba(10, 15, 25, 0.95);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        position: sticky;
        top: 0;
        z-index: 100;
        backdrop-filter: blur(12px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.5);
    }

    .navbar-container {
        max-width: 80rem;
        margin: 0 auto;
        padding: 0 1rem;
        height: 4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .brand-link {
        font-family: 'Poppins', sans-serif;
        font-weight: 900;
        font-size: 1.25rem;
        color: white;
        text-decoration: none;
        background: linear-gradient(to right, #60A5FA, #A78BFA);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .navbar-menu {
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .nav-link {
        color: #9CA3AF;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        position: relative;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
    }

    .nav-link:hover {
        color: white;
        background-color: rgba(255, 255, 255, 0.1);
    }

    .nav-link.active-bench {
        color: #111827 !important;
        background-color: #F59E0B !important;
        box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);
    }

    /* Pet Notification Style */
    .pet-notification {
        display: inline-block;
        margin-left: 0.5rem;
        animation: bounce 1s infinite;
        color: #FACC15;
        font-size: 1.2em;
        vertical-align: middle;
        text-shadow: 0 0 5px rgba(250, 204, 21, 0.5);
    }

    @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-3px); }
    }

    .navbar-end {
        position: relative;
        min-width: 150px; /* Space for language switcher */
        display: flex;
        align-items: center;
        gap: 1rem;
        justify-content: flex-end;
    }

    .navbar-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 30px;
        height: 21px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 101;
    }

    .bar {
        height: 3px;
        width: 100%;
        background-color: white;
        border-radius: 10px;
        transition: all 0.3s ease;
    }

    @media (max-width: 900px) {
        .navbar-toggle {
            display: flex;
        }

        .navbar-menu {
            position: fixed;
            top: 4rem; /* Below navbar */
            left: 0;
            width: 100%;
            background-color: #1F2937;
            flex-direction: column;
            gap: 0;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease-out;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .navbar-menu.active {
            max-height: 400px; /* Arbitrary large height */
        }

        .nav-link {
            width: 100%;
            text-align: center;
            padding: 1.5rem 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .nav-link:last-child {
            border-bottom: none;
        }
    }
</style>

<script>
    // Mobile Menu Toggle
    const toggle = document.getElementById('navbar-toggle');
    const menu = document.getElementById('navbar-menu');

    if (toggle && menu) {
        toggle.addEventListener('click', () => {
            menu.classList.toggle('active');
            // Animate hamburger (optional simple rotation)
        });
    }

    // Pet Notification Logic
    function checkPetNotification() {
        try {
            // Check if user has a pet
            const hasPet = localStorage.getItem('pixel_pet');
            // Check if notification already seen
            const notificationSeen = localStorage.getItem('pet_notification_seen');

            if (hasPet && !notificationSeen) {
                // Create indicator
                const indicator = document.createElement('span');
                indicator.className = 'pet-notification';
                indicator.textContent = '⬅'; // Or ✨
                indicator.setAttribute('aria-label', 'New Pet!');

                // Assuming pet link exists somewhere or we want to add the indicator somewhere
                // (The original code seems to have had a specific target that got lost. Let's just catch the error)
            }
        } catch (e) {
            console.warn('Pet notification check failed:', e);
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        checkPetNotification();

        // Also highlight active link
        const currentPath = window.location.pathname;
        const currentSearch = window.location.search;
        const urlParams = new URLSearchParams(currentSearch);
        const activeTab = urlParams.get('tab') || 'home';

        document.querySelectorAll('.nav-link').forEach(link => {
            const href = link.getAttribute('href');

            // Handle active state for benchmark tabs on homepage
            if (currentPath === '/' && href === '/') {
                if (activeTab === 'home') {
                    link.classList.add('active-bench');
                } else {
                    link.classList.remove('active-bench');
                }
            }
            // Regular links
            else if (href === currentPath && currentPath !== '/') {
                link.style.color = '#60A5FA';
                link.style.fontWeight = '700';
            }

            // Intercept home click to prevent reload if already on homepage
            if (href === '/') {
                link.addEventListener('click', (e) => {
                    if (window.location.pathname === '/') {
                        e.preventDefault();
                        const newTab = 'home';

                        // Update URL without reload
                        window.history.pushState({}, '', '/');

                        // Update UI
                        document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active-bench'));
                        link.classList.add('active-bench');

                        // Trigger custom event so index.astro can update the view
                        window.dispatchEvent(new CustomEvent('benchmarkTabChanged', { detail: newTab }));
                    }
                });
            }
        });
    });
</script>
